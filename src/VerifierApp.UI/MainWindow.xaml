<Window x:Class="VerifierApp.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Inter-Knot Arena Verifier"
        Height="780"
        Width="1240"
        MinHeight="720"
        MinWidth="1080"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/Assets/app-icon.ico"
        FontFamily="Bahnschrift">
    <Window.Resources>
        <SolidColorBrush x:Key="ShellTextPrimaryBrush" Color="#F8FAFF"/>
        <SolidColorBrush x:Key="ShellTextMutedBrush" Color="#9FB0CC"/>
        <SolidColorBrush x:Key="ShellCardBrush" Color="#CC0F1B31"/>
        <SolidColorBrush x:Key="ShellCardAltBrush" Color="#E30D1628"/>
        <SolidColorBrush x:Key="ShellBorderBrush" Color="#365078"/>
        <SolidColorBrush x:Key="ShellInputBrush" Color="#0B1322"/>
        <SolidColorBrush x:Key="ShellInputBorderBrush" Color="#3D5B86"/>

        <Style x:Key="PanelCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource ShellCardBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ShellBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="18"/>
        </Style>

        <Style x:Key="InputTextStyle" TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Background" Value="{StaticResource ShellInputBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource ShellTextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ShellInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="InputPasswordStyle" TargetType="PasswordBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Background" Value="{StaticResource ShellInputBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource ShellTextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ShellInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Background" Value="#0EA5E9"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="SecondaryActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Background" Value="#17243D"/>
            <Setter Property="Foreground" Value="#F6FAFF"/>
            <Setter Property="BorderBrush" Value="#3E5F8F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="DangerActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Width" Value="132"/>
            <Setter Property="Background" Value="#3F1521"/>
            <Setter Property="Foreground" Value="#FFE6EC"/>
            <Setter Property="BorderBrush" Value="#A54B64"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#070C16" Offset="0"/>
                <GradientStop Color="#0C162A" Offset="0.45"/>
                <GradientStop Color="#111E37" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Canvas IsHitTestVisible="False">
            <Ellipse Width="720" Height="720" Canvas.Left="-210" Canvas.Top="-150" Fill="#223D6A" Opacity="0.23"/>
            <Ellipse Width="630" Height="630" Canvas.Right="-190" Canvas.Bottom="-220" Fill="#1A6AA1" Opacity="0.18"/>
            <Rectangle Width="900" Height="900" Canvas.Left="120" Canvas.Top="-470" Fill="#FF6A00" Opacity="0.05" RenderTransformOrigin="0.5,0.5">
                <Rectangle.RenderTransform>
                    <RotateTransform Angle="25"/>
                </Rectangle.RenderTransform>
            </Rectangle>
        </Canvas>

        <Border Margin="24"
                Padding="24"
                CornerRadius="24"
                Background="#D40A1220"
                BorderBrush="#3D5A84"
                BorderThickness="1.2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Width="56" Height="56" CornerRadius="14" Background="#122541" BorderBrush="#3D5B87" BorderThickness="1">
                        <Image Source="pack://application:,,,/Assets/app-icon.png" Width="44" Height="44" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="16,2,0,0">
                        <TextBlock Text="INTER-KNOT ARENA VERIFIER"
                                   Foreground="{StaticResource ShellTextPrimaryBrush}"
                                   FontSize="29"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Desktop control center for account scan and match verification"
                                   Foreground="{StaticResource ShellTextMutedBrush}"
                                   FontSize="14"/>
                    </StackPanel>

                    <Border Grid.Column="2"
                            Background="#111E35"
                            BorderBrush="#3D5A84"
                            BorderThickness="1"
                            CornerRadius="999"
                            Padding="13,7"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="SessionDot" Width="11" Height="11" Fill="#F43F5E" VerticalAlignment="Center"/>
                            <TextBlock x:Name="SessionBadgeText" Margin="8,0,0,0" Text="Not connected" Foreground="#E2EFFF" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid x:Name="LoginPanel">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.18*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <Border Margin="0,0,16,0"
                                CornerRadius="20"
                                BorderBrush="#3A5680"
                                BorderThickness="1.2"
                                Padding="24">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#153056" Offset="0"/>
                                    <GradientStop Color="#111F38" Offset="0.58"/>
                                    <GradientStop Color="#0E1728" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Launch Secure Verification"
                                           Foreground="{StaticResource ShellTextPrimaryBrush}"
                                           FontSize="34"
                                           FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="1"
                                           Margin="0,14,0,0"
                                           TextWrapping="Wrap"
                                           Foreground="#D0DBEF"
                                           FontSize="16"
                                           Text="Authenticate once, then run visible-roster OCR import and anti-cheat match monitoring from a single desktop console."/>

                                <Grid Grid.Row="2" Margin="0,22,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Border Style="{StaticResource PanelCardStyle}" Background="#7A10233E" BorderBrush="#4B6E9F">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="01" Foreground="#79D2FF" FontSize="26" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,14,0"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="Account Sign-In" Foreground="#F8FAFF" FontWeight="SemiBold" FontSize="16"/>
                                                <TextBlock Text="Email or Google browser flow. Token stored with DPAPI." Foreground="#AFC1DD"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Row="1" Margin="0,12,0,0" Style="{StaticResource PanelCardStyle}" Background="#7A122740" BorderBrush="#5075A7">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="02" Foreground="#79D2FF" FontSize="26" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,14,0"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="Roster Snapshot Scan" Foreground="#F8FAFF" FontWeight="SemiBold" FontSize="16"/>
                                                <TextBlock Text="Current OCR path imports UID and the roster slice visible on screen. Full account overwrite stays disabled." Foreground="#AFC1DD"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Row="2" Margin="0,12,0,0" Style="{StaticResource PanelCardStyle}" Background="#7A10263E" BorderBrush="#4E74A4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="03" Foreground="#79D2FF" FontSize="26" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,14,0"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="Match Evidence" Foreground="#F8FAFF" FontWeight="SemiBold" FontSize="16"/>
                                                <TextBlock Text="Precheck and in-run CV evidence with verifier signatures." Foreground="#AFC1DD"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Row="3" Margin="0,18,0,0" CornerRadius="14" Background="#79101C31" BorderBrush="#43648F" BorderThickness="1" Padding="14">
                                        <TextBlock TextWrapping="Wrap" Foreground="#BCD1EC">
                                            <Run Text="- No game process memory reading or DLL injection"/>
                                            <LineBreak/>
                                            <Run Text="- Browser OAuth callback with device code exchange"/>
                                            <LineBreak/>
                                            <Run Text="- Local encrypted verifier token storage"/>
                                        </TextBlock>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource PanelCardStyle}" Background="{StaticResource ShellCardAltBrush}">
                            <StackPanel>
                                <TextBlock Text="Sign In"
                                           Foreground="{StaticResource ShellTextPrimaryBrush}"
                                           FontSize="30"
                                           FontWeight="SemiBold"/>
                                <TextBlock Margin="0,5,0,0"
                                           Foreground="{StaticResource ShellTextMutedBrush}"
                                           FontSize="14"
                                           Text="Choose authentication method. Dashboard unlocks after success."/>

                                <TextBlock Margin="0,20,0,6" Text="API URL" Foreground="#D4E0F5" FontWeight="SemiBold"/>
                                <TextBox x:Name="ApiUrlTextBox" Style="{StaticResource InputTextStyle}" Text="http://localhost:4000"/>

                                <Border Margin="0,18,0,0" Padding="12" CornerRadius="12" Background="#101D32" BorderBrush="#37537C" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Email Login" Foreground="#F7FBFF" FontWeight="SemiBold"/>
                                        <TextBlock Margin="0,2,0,0" Text="Use your Inter-Knot Arena website credentials." Foreground="#A8BDDA"/>
                                    </StackPanel>
                                </Border>

                                <TextBlock Margin="0,12,0,6" Text="Email" Foreground="#D4E0F5" FontWeight="SemiBold"/>
                                <TextBox x:Name="EmailTextBox" Style="{StaticResource InputTextStyle}"/>

                                <TextBlock Margin="0,10,0,6" Text="Password" Foreground="#D4E0F5" FontWeight="SemiBold"/>
                                <PasswordBox x:Name="PasswordInput"
                                             Style="{StaticResource InputPasswordStyle}"
                                             KeyDown="PasswordInput_OnKeyDown"/>

                                <Button x:Name="EmailLoginButton"
                                        Margin="0,14,0,0"
                                        Style="{StaticResource PrimaryActionButtonStyle}"
                                        Content="Sign in with Email"
                                        Click="EmailLoginButton_OnClick"/>

                                <Grid Margin="0,14,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Height="1" Background="#37537A" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Margin="10,0" Text="or" Foreground="#7F97B8" FontWeight="SemiBold"/>
                                    <Border Grid.Column="2" Height="1" Background="#37537A" VerticalAlignment="Center"/>
                                </Grid>

                                <Button x:Name="GoogleLoginButton"
                                        Margin="0,14,0,0"
                                        Style="{StaticResource SecondaryActionButtonStyle}"
                                        Content="Continue with Google (Browser)"
                                        Click="GoogleLoginButton_OnClick"/>

                                <Border Margin="0,16,0,0" Padding="10" CornerRadius="10" Background="#10182B" BorderBrush="#32496C" BorderThickness="1">
                                    <TextBlock TextWrapping="Wrap" Foreground="#AFC2DF" FontSize="13">
                                        Google sign-in opens your default browser and returns to this app through loopback callback.
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid x:Name="DashboardPanel" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource PanelCardStyle}" Background="#CB0E1A2F" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Verifier Session Active" Foreground="#F7FBFF" FontSize="21" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="DisplayNameText" Foreground="#AFC3E0" FontSize="14" Text="Authenticated session"/>
                                </StackPanel>
                                <Button x:Name="LogoutButton"
                                        Grid.Column="1"
                                        Style="{StaticResource DangerActionButtonStyle}"
                                        Content="Log Out"
                                        Click="LogoutButton_OnClick"/>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Margin="0,0,8,0" Style="{StaticResource PanelCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Roster Sync" Foreground="#F7FBFF" FontSize="20" FontWeight="SemiBold"/>
                                    <TextBlock Margin="0,2,0,12" Foreground="#A7B9D7" Text="Run OCR import for the visible roster slice or multi-page full sync with built-in detail capture."/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Region" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="#D1DDF2" FontWeight="SemiBold"/>
                                        <ComboBox x:Name="RegionComboBox" Grid.Column="1" Width="132" SelectedIndex="0">
                                            <ComboBoxItem Content="OTHER"/>
                                            <ComboBoxItem Content="NA"/>
                                            <ComboBoxItem Content="EU"/>
                                            <ComboBoxItem Content="ASIA"/>
                                            <ComboBoxItem Content="SEA"/>
                                        </ComboBox>
                                        <CheckBox x:Name="FullSyncCheckBox"
                                                  Grid.Column="2"
                                                  Margin="14,0,0,0"
                                                  VerticalAlignment="Center"
                                                  Content="Full Sync (multi-page beta)"
                                                  IsChecked="False"
                                                  Foreground="#D1DDF2"
                                                  FontWeight="SemiBold"/>
                                    </Grid>

                                    <TextBlock Margin="0,10,0,0"
                                               TextWrapping="Wrap"
                                               Foreground="#F0C88A"
                                               Text="Full Sync now walks roster pages under active input lock and only applies overwrite when terminal-slice coverage is confirmed. Built-in follow-up capture still focuses on agent detail screens, so missing equipment fields are preserved unless richer captures are available."/>

                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Locale" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="#D1DDF2" FontWeight="SemiBold"/>
                                        <ComboBox x:Name="LocaleComboBox" Grid.Column="1" Width="96" SelectedIndex="0">
                                            <ComboBoxItem Content="EN"/>
                                            <ComboBoxItem Content="RU"/>
                                        </ComboBox>
                                        <TextBlock Grid.Column="2" Text="Resolution" Margin="14,0,10,0" VerticalAlignment="Center" Foreground="#D1DDF2" FontWeight="SemiBold"/>
                                        <ComboBox x:Name="ResolutionComboBox" Grid.Column="3" Width="96" SelectedIndex="0">
                                            <ComboBoxItem Content="Auto"/>
                                            <ComboBoxItem Content="1080p"/>
                                            <ComboBoxItem Content="1440p"/>
                                        </ComboBox>
                                        <TextBlock Grid.Column="4" Text="Profile" Margin="14,0,10,0" VerticalAlignment="Center" Foreground="#D1DDF2" FontWeight="SemiBold"/>
                                        <ComboBox x:Name="ScanProfileComboBox" Grid.Column="5" Width="104" SelectedIndex="0">
                                            <ComboBoxItem Content="Fast"/>
                                            <ComboBoxItem Content="Deep"/>
                                        </ComboBox>
                                    </Grid>

                                    <Button x:Name="RosterScanButton"
                                            Margin="0,14,0,0"
                                            Style="{StaticResource PrimaryActionButtonStyle}"
                                            Content="Run OCR Scan + Import"
                                            Click="RosterScanButton_OnClick"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Margin="8,0,0,0" Style="{StaticResource PanelCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Match Monitor" Foreground="#F7FBFF" FontSize="20" FontWeight="SemiBold"/>
                                    <TextBlock Margin="0,2,0,12" Foreground="#A7B9D7" Text="Send precheck and in-run verification evidence."/>

                                    <TextBlock Text="Match ID" Margin="0,0,0,6" Foreground="#D1DDF2" FontWeight="SemiBold"/>
                                    <TextBox x:Name="MatchIdTextBox"
                                             Style="{StaticResource InputTextStyle}"/>

                                    <Button x:Name="MatchMonitorButton"
                                            Margin="0,14,0,0"
                                            Style="{StaticResource SecondaryActionButtonStyle}"
                                            Content="Start Match Monitor"
                                            Click="MatchMonitorButton_OnClick"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Grid.Row="2" Style="{StaticResource PanelCardStyle}" Background="#CC091224">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Activity Log"
                                           Foreground="#F7FBFF"
                                           FontSize="17"
                                           FontWeight="SemiBold"
                                           Margin="2,0,0,10"/>
                                <TextBox Grid.Row="1"
                                         x:Name="StatusTextBox"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Background="#0A1222"
                                         Foreground="#CFE0FA"
                                         BorderBrush="#294263"
                                         BorderThickness="1"
                                         FontFamily="Cascadia Code"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
