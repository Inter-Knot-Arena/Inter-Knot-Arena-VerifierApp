<Window x:Class="VerifierApp.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Inter-Knot Arena Verifier"
        Height="760"
        Width="1160"
        MinHeight="700"
        MinWidth="1040"
        WindowStartupLocation="CenterScreen"
        Icon="Assets/app-icon.ico"
        FontFamily="Bahnschrift">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0D1117" Offset="0"/>
                <GradientStop Color="#111827" Offset="0.55"/>
                <GradientStop Color="#171923" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Border Margin="22"
                Padding="22"
                CornerRadius="20"
                Background="#DD0F172A"
                BorderBrush="#334155"
                BorderThickness="1.2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="INTER-KNOT ARENA VERIFIER"
                                   Foreground="#F8FAFC"
                                   FontSize="26"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Secure roster sync and match verification"
                                   Foreground="#94A3B8"
                                   FontSize="14"/>
                    </StackPanel>
                    <Border Grid.Column="1"
                            Background="#1E293B"
                            BorderBrush="#334155"
                            BorderThickness="1"
                            CornerRadius="999"
                            Padding="12,6"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="SessionDot" Width="10" Height="10" Fill="#F43F5E" VerticalAlignment="Center"/>
                            <TextBlock x:Name="SessionBadgeText" Margin="8,0,0,0" Text="Not connected" Foreground="#E2E8F0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid x:Name="LoginPanel">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.35*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <Border Margin="0,0,16,0"
                                CornerRadius="18"
                                Background="#1E293B"
                                BorderBrush="#334155"
                                BorderThickness="1.2"
                                Padding="22">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Welcome to VerifierApp"
                                           Foreground="#F8FAFC"
                                           FontSize="30"
                                           FontWeight="SemiBold"/>
                                <TextBlock Margin="0,12,0,0"
                                           TextWrapping="Wrap"
                                           Foreground="#CBD5E1"
                                           FontSize="15"
                                           Text="Sign in first. After authentication, roster scan and match-monitor functions become available."/>
                                <Border Margin="0,22,0,0"
                                        Padding="16"
                                        CornerRadius="14"
                                        Background="#0F172A"
                                        BorderBrush="#334155"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Security Model" Foreground="#F8FAFC" FontWeight="SemiBold"/>
                                        <TextBlock Margin="0,8,0,0" Foreground="#94A3B8" Text="• No memory reading or DLL injection into game process."/>
                                        <TextBlock Foreground="#94A3B8" Text="• OAuth device flow + signed evidence payloads."/>
                                        <TextBlock Foreground="#94A3B8" Text="• Local encrypted token storage (DPAPI)."/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1"
                                CornerRadius="18"
                                Background="#0F172A"
                                BorderBrush="#334155"
                                BorderThickness="1.2"
                                Padding="24">
                            <StackPanel>
                                <TextBlock Text="Sign In"
                                           Foreground="#F8FAFC"
                                           FontSize="24"
                                           FontWeight="SemiBold"/>
                                <TextBlock Margin="0,4,0,0"
                                           Foreground="#94A3B8"
                                           Text="Choose email login or Google login"/>

                                <TextBlock Margin="0,18,0,6" Text="API URL" Foreground="#CBD5E1"/>
                                <TextBox x:Name="ApiUrlTextBox"
                                         Height="38"
                                         Padding="10,6"
                                         Background="#111827"
                                         Foreground="#F8FAFC"
                                         BorderBrush="#334155"
                                         BorderThickness="1"
                                         Text="http://localhost:4000"/>

                                <TextBlock Margin="0,16,0,6" Text="Email" Foreground="#CBD5E1"/>
                                <TextBox x:Name="EmailTextBox"
                                         Height="38"
                                         Padding="10,6"
                                         Background="#111827"
                                         Foreground="#F8FAFC"
                                         BorderBrush="#334155"
                                         BorderThickness="1"/>

                                <TextBlock Margin="0,10,0,6" Text="Password" Foreground="#CBD5E1"/>
                                <PasswordBox x:Name="PasswordInput"
                                             Height="38"
                                             Padding="10,6"
                                             Background="#111827"
                                             Foreground="#F8FAFC"
                                             BorderBrush="#334155"
                                             BorderThickness="1"
                                             KeyDown="PasswordInput_OnKeyDown"/>

                                <Button x:Name="EmailLoginButton"
                                        Margin="0,14,0,0"
                                        Height="42"
                                        Background="#0EA5E9"
                                        Foreground="White"
                                        BorderThickness="0"
                                        FontWeight="SemiBold"
                                        Content="Sign in with Email"
                                        Click="EmailLoginButton_OnClick"/>

                                <Button x:Name="GoogleLoginButton"
                                        Margin="0,10,0,0"
                                        Height="42"
                                        Background="#111827"
                                        Foreground="#F8FAFC"
                                        BorderBrush="#334155"
                                        BorderThickness="1"
                                        FontWeight="SemiBold"
                                        Content="Sign in with Google (Browser)"
                                        Click="GoogleLoginButton_OnClick"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid x:Name="DashboardPanel" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="DisplayNameText"
                                       Foreground="#E2E8F0"
                                       FontSize="16"
                                       VerticalAlignment="Center"
                                       Text="Authenticated session"/>
                            <Button x:Name="LogoutButton"
                                    Grid.Column="1"
                                    Width="120"
                                    Height="36"
                                    Background="#111827"
                                    Foreground="#F8FAFC"
                                    BorderBrush="#334155"
                                    BorderThickness="1"
                                    Content="Log Out"
                                    Click="LogoutButton_OnClick"/>
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Margin="0,0,8,0"
                                    CornerRadius="14"
                                    Background="#111827"
                                    BorderBrush="#334155"
                                    BorderThickness="1"
                                    Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Roster Sync" Foreground="#F8FAFC" FontSize="18" FontWeight="SemiBold"/>
                                    <TextBlock Margin="0,2,0,12" Foreground="#94A3B8" Text="OCR full-scan + import"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Region" Width="58" Foreground="#CBD5E1" VerticalAlignment="Center"/>
                                        <ComboBox x:Name="RegionComboBox" Width="120" SelectedIndex="0">
                                            <ComboBoxItem Content="OTHER"/>
                                            <ComboBoxItem Content="NA"/>
                                            <ComboBoxItem Content="EU"/>
                                            <ComboBoxItem Content="ASIA"/>
                                            <ComboBoxItem Content="SEA"/>
                                        </ComboBox>
                                        <CheckBox x:Name="FullSyncCheckBox" Margin="14,0,0,0" Content="Full Sync" IsChecked="True" VerticalAlignment="Center" Foreground="#CBD5E1"/>
                                    </StackPanel>
                                    <Button x:Name="RosterScanButton"
                                            Margin="0,14,0,0"
                                            Height="40"
                                            Background="#2563EB"
                                            Foreground="White"
                                            BorderThickness="0"
                                            FontWeight="SemiBold"
                                            Content="Run Roster Scan + Import"
                                            Click="RosterScanButton_OnClick"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1"
                                    Margin="8,0,0,0"
                                    CornerRadius="14"
                                    Background="#111827"
                                    BorderBrush="#334155"
                                    BorderThickness="1"
                                    Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Match Monitor" Foreground="#F8FAFC" FontSize="18" FontWeight="SemiBold"/>
                                    <TextBlock Margin="0,2,0,12" Foreground="#94A3B8" Text="Precheck + in-run evidence"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Match ID" Width="70" Foreground="#CBD5E1" VerticalAlignment="Center"/>
                                        <TextBox x:Name="MatchIdTextBox"
                                                 Width="250"
                                                 Padding="10,6"
                                                 Background="#0B1220"
                                                 Foreground="#F8FAFC"
                                                 BorderBrush="#334155"
                                                 BorderThickness="1"/>
                                    </StackPanel>
                                    <Button x:Name="MatchMonitorButton"
                                            Margin="0,14,0,0"
                                            Height="40"
                                            Background="#7C3AED"
                                            Foreground="White"
                                            BorderThickness="0"
                                            FontWeight="SemiBold"
                                            Content="Start Match Monitor"
                                            Click="MatchMonitorButton_OnClick"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Grid.Row="2"
                                CornerRadius="14"
                                Background="#0B1220"
                                BorderBrush="#334155"
                                BorderThickness="1"
                                Padding="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Activity Log"
                                           Foreground="#F8FAFC"
                                           FontWeight="SemiBold"
                                           Margin="2,0,0,8"/>
                                <TextBox Grid.Row="1"
                                         x:Name="StatusTextBox"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Background="#0B1220"
                                         BorderThickness="0"
                                         Foreground="#C7D2FE"
                                         FontFamily="Cascadia Code"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
